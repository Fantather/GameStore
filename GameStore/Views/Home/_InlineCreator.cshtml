@model InlineCreatorViewModel

<form class="card p-1" asp-controller="Home" asp-action="CreateProduct">
    <div class="row mb-2">
        <label asp-for="@Model.Product.Name" class="col-4 col-form-label">@Html.DisplayNameFor(model => model.Product.Name)</label>
        <div class="col-8">
            <input asp-for="@Model.Product.Name" class="form-control" />
        </div>
    </div>
    <div class="row mb-2">
        <label asp-for="@Model.Product.PurchasePrice" class="col-4 col-form-label">@Html.DisplayNameFor(model => model.Product.PurchasePrice)</label>
        <div class="col-8">
            <input asp-for="@Model.Product.PurchasePrice" class="form-control" />
        </div>
    </div>
    <div class="row mb-2">
        <label asp-for="@Model.Product.RetailPrice" class="col-4 col-form-label">@Html.DisplayNameFor(model => model.Product.RetailPrice)</label>
        <div class="col-8">
            <input asp-for="@Model.Product.RetailPrice" class="form-control" />
        </div>
    </div>
    <div class="row mb-2">
        <label asp-for="@Model.Product.CategoryId" class="col-4 col-form-label">@Html.DisplayNameFor(model => model.Product.CategoryId)</label>
        <div class="col-8">
            <select asp-for="@Model.Product.CategoryId">
                @foreach(var category in Model.Categories)
                {
                    <option value="@category.Id">@category.Name</option>
                }
            </select>
        </div>
    </div>
    <button type="submit">Создать</button>
</form>