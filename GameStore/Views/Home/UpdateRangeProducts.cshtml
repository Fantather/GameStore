@model UpdateRangeProductsViewModel

@{
    ViewData["Title"] = "UpdateRangeProducts";
}

<h1>UpdateRangeProducts</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<form asp-controller="Home" asp-action="UpdateRangeProducts" method="post">
    <table class="table">
        <thead>
            <tr>
                <th>
                    @Html.DisplayNameFor(model => model.Products[0].Name)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Products[0].PurchasePrice)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Products[0].RetailPrice)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Products[0].CategoryId)
                </th>
            </tr>
        </thead>
        <tbody>
            @for(int i = 0; i < Model.Products.Count; i++)
            {
            <tr>
                <input type="hidden" asp-for="@Model.Products[i].Id" />
                <td>
                    <input asp-for="@Model.Products[i].Name" class="form-control" />
                </td>
                <td>
                    <input asp-for="@Model.Products[i].PurchasePrice" class="form-control" />
                </td>
                <td>
                    <input asp-for="@Model.Products[i].RetailPrice" class="form-control" />
                </td>
                <td>
                    <select asp-for="@Model.Products[i].CategoryId" class="form-control">
                        @if (Model.Products[i].CategoryId == 0)
                        {
                            <option disabled selected>Выберите категорию</option>
                        }
                        @foreach(var category in Model.Categories)
                        {
                            <option value="@category.Id">@category.Name</option>
                        }
                    </select>
                </td>
            </tr>
            }
        </tbody>
    </table>
    <button class="btn btn-primary" type="submit">Сохранить</button>
</form>
